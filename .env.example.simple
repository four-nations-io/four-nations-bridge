# ════════════════════════════════════════════════════════════════════════════
#  four-nations-bridge — SIMPLE config (creator quick-start)
# ════════════════════════════════════════════════════════════════════════════
#
# The install script writes a .env like this FOR you from a few prompts — you
# normally never hand-edit it. This trimmed file is the human reference: the
# handful of fields that actually matter, plus the optional performance knobs
# (which you can also change later from the web app, no file editing, no
# restart). For the exhaustive list of every supported variable, see the full
# .env.example next to this one.
#
# To use it manually: copy to ".env" in the same folder as your
# docker-compose.yml, fill in the REQUIRED block, then `docker compose up -d`.

# ─── REQUIRED ───────────────────────────────────────────────────────────────
# These come from your install instructions / your account.

# Where the service lives (from your install instructions).
CONTENT_BRIDGE_SAAS_URL=wss://bridge.example.com

# Optional override for the "Browse your content →" link shown after pairing.
# Released bridges already point at the official web app, so you normally LEAVE
# THIS BLANK. Set it only for a self-hosted or custom web app (or for testing).
# This is the https web app, NOT the wss service URL above.
# CONTENT_BRIDGE_APP_URL=https://app.example.com

# Pairing code that links this bridge to YOUR ACCOUNT. Treat it like a password.
# (Sign in on any device afterward and your library is there — pairing is
# account-level, not per-device.)
CONTENT_BRIDGE_PAIRING_CODE=

# Content encryption key — exactly 64 hex characters. Thumbnails + previews are
# encrypted with this before they ever leave your machine.
# Generate one with:  openssl rand -hex 32
CONTENT_BRIDGE_ENCRYPTION_KEY=

# Your content folder (host path). Mounted READ-ONLY — the bridge physically
# cannot modify or delete anything inside it.
CONTENT_BRIDGE_HOST_CONTENT_PATH=/path/to/your/content

# A folder the bridge fully owns for its own files (generated thumbnails,
# previews, and the pairing state). Keep this OUTSIDE your content folder.
CONTENT_BRIDGE_MANAGED_HOST_PATH=/path/to/bridge-managed

# The user the bridge RUNS AS, written as uid:gid. This is NOT a login or
# password — a container has no password; your machine's file permissions
# decide what this uid can touch. It MUST be able to READ the content folder
# above and READ+WRITE the working folder above. Find the right value:
#   stat -c '%u:%g' "/path/to/your/content"     # the uid:gid that owns your content
#   id                                            # shows your own uid=… gid=…
# SET THIS to your value. If you leave it blank the bridge falls back to its
# built-in uid (1031:100), which only works if 1031 already has access — so it
# will usually be wrong for you. Either way, if the bridge can't read content or
# write the working folder it logs a clear permission error at startup naming
# the uid and how to fix it (see also fix-perms.sh / setup-account-prompt.txt).
CONTENT_BRIDGE_RUN_AS_USER=

# This machine's platform:  linux | darwin (macOS) | win32 (Windows)
CONTENT_BRIDGE_DEVICE_PLATFORM=linux

# Name for this bridge in your account's device list. Used when AUTO-PAIRING
# (with the browser wizard you type the name there instead). Defaults to this
# machine's hostname if left blank. This is the INITIAL name, set at first
# pairing — once paired, the saved name is what shows, so changing it here later
# has no effect.
CONTENT_BRIDGE_DEVICE_LABEL=

# Keep all generated files in the bridge's own cache folder, never inside your
# content tree. Recommended — leave as-is.
CONTENT_BRIDGE_THUMB_OUTPUT_MODE=cache_dir


# ─── HOW YOU FINISH SETUP (pick ONE — default is the browser wizard) ────────
# Default (leave the options below blank): open http://localhost:8124 on THIS
# machine and the wizard walks you through pairing + confirming your folder.
#
# Option A — AUTO-PAIR on boot (no browser; ideal for a headless NAS). The
# bridge verifies the pairing code above and pairs itself at startup. Set a
# CONTENT_BRIDGE_DEVICE_LABEL above so it has a name.
# CONTENT_BRIDGE_AUTO_PAIR=true
#
# Option B — LAN setup page (finish from another computer on your network).
# Binds the setup page to the network, protected by a one-time token. Then open
# http://THIS-MACHINE-IP:8124/?token=<token> from your laptop.
# Generate a token with:  openssl rand -hex 24
# CONTENT_BRIDGE_SETUP_UI_LAN=true
# CONTENT_BRIDGE_SETUP_TOKEN=
# CONTENT_BRIDGE_SETUP_UI_BIND=0.0.0.0
# CONTENT_BRIDGE_SETUP_UI_HOST=          # optional: reach the NAS by name, e.g. nas.local


# ─── PERFORMANCE (OPTIONAL — you can ignore this whole section) ─────────────
# You do NOT need to set any of these. The defaults are sensible, and you can
# change them LIVE from the web app's bridge settings — no file edit, no
# restart. They only affect how hard the bridge works your machine while it
# generates thumbnails/previews; they never change what your account can see.
#
# Thumbnails (still images). Higher concurrency = faster first sync, more CPU.
# CONTENT_BRIDGE_THUMB_CONCURRENCY=1
# CONTENT_BRIDGE_THUMB_DELAY_MS=200          # pause between items (politeness)
# CONTENT_BRIDGE_THUMB_CPU_NICE=15           # 19 = lowest priority, 0 = normal
# CONTENT_BRIDGE_THUMB_MAX_DIM_PX=1080       # longest edge of a generated thumb
# CONTENT_BRIDGE_THUMB_JPEG_QUALITY=80
#
# Preview proxies (short 720p versions for smooth scrubbing).
# CONTENT_BRIDGE_PROXY_QUALITY_CRF=28        # higher = smaller file, lower quality
# CONTENT_BRIDGE_PROXY_THREADS=2             # 0 = use all cores
#
# Cache size + retention (the bridge's OWN disk — never your content).
# CONTENT_BRIDGE_CACHE_CAP_BYTES=2147483648  # 2 GiB hard ceiling
# CONTENT_BRIDGE_THUMB_CACHE_TTL_DAYS=90
