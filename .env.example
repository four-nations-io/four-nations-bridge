# four-nations-bridge — environment reference.
#
# The install script generates a .env for you from a few prompts, so you
# normally never edit this by hand. This file documents every supported
# variable for power users; .env.example.simple is the trimmed quick-start.
# Required values come from your account's Install Bridge page.

# ─── Which user the bridge runs as ─────────────────────────────────────────

# Run the bridge container as this uid:gid. The bridge only READS your content
# (the content mount is read-only) and read+writes its own working folders.
# Easiest correct value is the user that owns your content folder:
#   stat -c '%u:%g' /path/to/your/content
# Leave blank to use the image default (1031:100), which only works if that uid
# already has access — so it is usually wrong; set it to your value.
CONTENT_BRIDGE_RUN_AS_USER=

# ─── Required (from your account's Install Bridge page) ─────────────────────

# Bridge gateway WSS endpoint to connect to (wss://…).
CONTENT_BRIDGE_SAAS_URL=

# Single-use pairing code that links this bridge to YOUR ACCOUNT. The bridge
# exchanges it for its own per-device credential on first pair (the code itself
# is never the long-lived credential). Treat it like a password.
CONTENT_BRIDGE_PAIRING_CODE=

# Content encryption key — exactly 64 hex characters. Thumbnails + previews are
# encrypted with this on your machine before they ever leave it.
# Generate with: openssl rand -hex 32
CONTENT_BRIDGE_ENCRYPTION_KEY=

# Host path where your content lives (mounted READ-ONLY inside the container).
# Examples by host:
#   NAS:     /volume1/<your-share>/Content
#   macOS:   /Volumes/<your-share>/Content      (e.g. an SMB-mounted NAS share)
#   Windows: /mnt/c/Users/<you>/Content         (a path your WSL distro can see)
CONTENT_BRIDGE_HOST_CONTENT_PATH=

# A folder the bridge fully OWNS for its own files (generated thumbnails,
# previews, pairing state). Keep this OUTSIDE your content folder.
CONTENT_BRIDGE_MANAGED_HOST_PATH=

# ─── Informational / optional ──────────────────────────────────────────────

# Name for this bridge in your account's device list. Free-form; defaults to
# this machine's hostname when blank. Set at first pairing.
CONTENT_BRIDGE_DEVICE_LABEL=

# This machine's platform — informational only: linux | darwin | win32.
CONTENT_BRIDGE_DEVICE_PLATFORM=linux

# Web app base URL (https://…) — only used to build the "browse your content"
# link shown after pairing. Released bridges already point at the official web
# app, so leave this blank unless you self-host or are testing.
# CONTENT_BRIDGE_APP_URL=

# Keep all generated files in the bridge's own cache folder, never inside your
# content tree. Recommended — leave as-is.
CONTENT_BRIDGE_THUMB_OUTPUT_MODE=cache_dir

# Override the setup-UI port if 8124 conflicts with something else. Bound to
# 127.0.0.1 only unless LAN mode (below) is enabled.
# CONTENT_BRIDGE_SETUP_UI_PORT=8124

# Where the pairing-state file (paired.json) lives inside the container.
# Defaults under the bridge-owned managed folder. Re-pair by deleting it.
# CONTENT_BRIDGE_STATE_DIR=/data/managed/_state

# ─── Pairing without a browser (headless NAS / another computer) ────────────

# (1) AUTO-PAIR ON BOOT — no browser at all. When true AND a valid pairing code
# is set above, the bridge verifies it with the gateway and pairs itself at
# startup (named from CONTENT_BRIDGE_DEVICE_LABEL).
# CONTENT_BRIDGE_AUTO_PAIR=false

# (2) LAN SETUP PAGE — finish setup from another computer on your network,
# protected by a one-time token. Set these together:
#   CONTENT_BRIDGE_SETUP_UI_LAN=true
#   CONTENT_BRIDGE_SETUP_TOKEN=<32+ random hex; the installer generates one>
#   CONTENT_BRIDGE_SETUP_UI_BIND=0.0.0.0
# In LAN mode every non-loopback request must carry the token; an empty token
# fails closed (503 to every off-box request).
# CONTENT_BRIDGE_SETUP_UI_LAN=false
# CONTENT_BRIDGE_SETUP_TOKEN=
# Optional extra Host header to allow in LAN mode (reach the NAS by name, e.g.
# nas.local). Private-IP-literal hosts are allowed without this.
# CONTENT_BRIDGE_SETUP_UI_HOST=
# CONTENT_BRIDGE_SETUP_UI_BIND=127.0.0.1

# ─── Thumbnail / preview performance (optional; sensible defaults) ──────────
# These only affect how hard the bridge works your machine generating
# thumbnails/previews. All are also live-overridable from the web app's bridge
# settings (same keys, minus the CONTENT_BRIDGE_ prefix, lowercased).

# Thumbnails. Higher concurrency = faster first sync, more CPU.
# CONTENT_BRIDGE_THUMB_CONCURRENCY=1
# CONTENT_BRIDGE_THUMB_DELAY_MS=200          # pause between items (politeness)
# CONTENT_BRIDGE_THUMB_CPU_NICE=15           # 19 = lowest priority, 0 = normal
# CONTENT_BRIDGE_THUMB_MAX_DIM_PX=1080       # longest edge of a generated thumb
# CONTENT_BRIDGE_THUMB_JPEG_QUALITY=80
# CONTENT_BRIDGE_THUMB_POSITIONS=5,25,50,75,95   # video frame positions (% of duration)

# 720p preview proxies (short H.264 versions for smooth scrubbing).
# CONTENT_BRIDGE_PROXY_QUALITY_CRF=28        # higher = smaller file, lower quality
# CONTENT_BRIDGE_PROXY_THREADS=2             # 0 = use all cores
# CONTENT_BRIDGE_PROXY_SKIP_BELOW_BYTES=100000000   # stream small sources directly

# Cache size + retention (the bridge's OWN disk — never your content).
# CONTENT_BRIDGE_CACHE_CAP_BYTES=2147483648  # 2 GiB hard ceiling (LRU eviction)
# CONTENT_BRIDGE_THUMB_CACHE_TTL_DAYS=90
# CONTENT_BRIDGE_PROXY_CACHE_TTL_MINUTES=25
# CONTENT_BRIDGE_CACHE_SWEEP_MINUTES=5

# Default project-template folder (host path) copied by "Create Project Folder".
# Must sit inside a content root the bridge can read. Empty = no default.
# CONTENT_BRIDGE_DEFAULT_TEMPLATE_PATH=
