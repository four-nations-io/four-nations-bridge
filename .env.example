# four-nations-bridge — per-deployment env vars.
#
# Copy this to `.env` in this same folder (gitignored). Each host (NAS, Mac,
# PC) maintains its own .env with values appropriate to that host. The
# docker-compose.yml defaults match the NAS deployment; Mac + PC override.

# ─── UID/GID the container runs as ─────────────────────────────────────────

# Run the bridge container as this UID:GID. Default `1031:100` matches
# four-nations-next's convention but only works if 1031 has write access to
# your content tree (it usually doesn't on personal NAS folders where files
# are owned by your DSM user). Synology ACLs sit on top of Unix perms — mode
# 777 alone isn't enough if 1031 isn't in the share's ACL.
#
# Recommendation: match the user that owns your content folder. Find it via:
#   stat -c '%u:%g' /volume1/photo/Content/Content Projects
# Then set CONTENT_BRIDGE_RUN_AS_USER to that value (e.g. 1028:100).
CONTENT_BRIDGE_RUN_AS_USER=

# ─── CREDENTIAL (one of: env bearer, or the V0.8.b setup wizard) ────────────

# Shared V0 bearer for PROD (used by docker-compose.yml). Must match the
# value in four-nations-web/.env's CONTENT_BRIDGE_BEARER. Min 32 chars.
# Generate with `openssl rand -base64 32` once, then paste the SAME value
# into:
#   - four-nations-web/.env on the NAS
#   - this .env on every device you pair (NAS, Mac, PC)
# SINCE V0.8.b this is OPTIONAL: leave it empty and the bridge boots UNPAIRED —
# the setup wizard at http://localhost:<setup-ui-port> then collects the
# pairing code and persists it to <state-dir>/paired.json instead. Operator
# deployments keep using this env path (it still counts as paired).
CONTENT_BRIDGE_BEARER=

# Shared V0 bearer for DEV (used by docker-compose.dev.yml). MUST be a
# distinct value from CONTENT_BRIDGE_BEARER above so a misrouted bridge
# can't accidentally connect to the wrong env. Same constraints — min 32
# chars, byte-identical with four-nations-web/.env's CONTENT_BRIDGE_BEARER_DEV.
# Generate with a separate `openssl rand -base64 32`.
CONTENT_BRIDGE_BEARER_DEV=

# ─── PER-DEPLOYMENT (NAS defaults work as-is; Mac + PC override) ───────────

# Absolute host path to your content folder. REQUIRED (Phase F cutover, planning
# doc 65): the compose mounts it READ-ONLY at its mirrored container path
# (/sources/host<host_path>), the bridge indexes from it, and auto-registers it as
# your source root on connect — so Browse + the folders panel work with zero CLI.
# Examples by host:
#   NAS:  /volume1/photo/Content/Content Projects
#   Mac:  /Volumes/photo/Content/Content Projects        (SMB-mounted NAS share)
#   PC:   //192.168.1.50/photo/Content/Content Projects  (SMB UNC path)
# (CONTENT_BRIDGE_SOURCE_ROOT is gone — the index root is derived from this path.)
CONTENT_BRIDGE_HOST_CONTENT_PATH=

# Where the bridge-gateway service lives (the WSS endpoint inside four-nations-web).
# Defaults to PROD gateway (port 8080). Examples by host:
#   NAS:  ws://172.17.0.1:8080      (default — Docker bridge gateway IP for cross-stack on same NAS)
#   Mac:  ws://192.168.1.50:8080    (NAS LAN IP)
#   PC:   ws://192.168.1.50:8080    (NAS LAN IP)
CONTENT_BRIDGE_SAAS_URL=

# Dev variant of the above — used by docker-compose.dev.yml. Default is
# 172.17.0.1:8082 (NAS Docker bridge gateway IP, dev gateway port). Mac/PC
# override to ws://192.168.1.50:8082.
CONTENT_BRIDGE_SAAS_URL_DEV=

# Device label — which deployment target this container represents. V0 enum:
#   operator-nas | operator-mac | operator-pc
# Default: operator-nas. Mac sets operator-mac; PC sets operator-pc.
CONTENT_BRIDGE_DEVICE_LABEL=

# Container platform — informational only. One of: linux | darwin | win32.
# Default: linux. Mac sets darwin; PC sets win32.
CONTENT_BRIDGE_DEVICE_PLATFORM=

# ─── V0.3 thumbnail config (required for V0.3+) ────────────────────────────

# Hex-encoded 32-byte AES-256 stub encryption key. Must match the value in
# four-nations-web/.env. Generate with `openssl rand -hex 32`. Used by V0.3+
# to encrypt thumbnails + byte-range previews. V0 only — V1.2 swaps to the
# browser-derived per-tenant CEK and removes this env var entirely.
CONTENT_BRIDGE_ENCRYPTION_KEY=

# Dev variant of the encryption key. Use a DIFFERENT random value from the
# prod one above so dev/prod stay isolated.
CONTENT_BRIDGE_ENCRYPTION_KEY_DEV=

# Sub-path inside each project folder where thumbs land. ALWAYS constrained
# to inside the project folder. Default `Pics/Bridge Thumbnails`. V0.4 adds
# a SaaS-side dropdown to change this without env edits.
# CONTENT_BRIDGE_THUMB_SUBPATH_WITHIN_PROJECT=Pics/Bridge Thumbnails

# Comma-separated thumb positions (% of video duration). Default
# `5,25,50,75,95` avoids 0/100 which often falls on black frames.
# CONTENT_BRIDGE_THUMB_POSITIONS=5,25,50,75,95

# Throttle knobs. Defaults are conservative (1 ffmpeg at a time, niced,
# 200ms pause between videos) so a creator's machine stays responsive during
# first-sync.
#
# For fast mode: set CONCURRENCY to (cpu_cores - 1) and DELAY_MS to 0.
# On a 4-core NAS, CONCURRENCY=3 typically cuts wall-clock 60-70% vs serial.
# Higher concurrency than (cores - 1) generally doesn't help because ffmpeg
# is CPU-bound; can hurt responsiveness of other NAS workloads.
# CONTENT_BRIDGE_THUMB_CONCURRENCY=1
# CONTENT_BRIDGE_THUMB_DELAY_MS=200
# CONTENT_BRIDGE_THUMB_CPU_NICE=15
# Thumb longest-edge max (px). Default 1080 — thumbs double as promo stills.
# Also live-overridable from the SaaS (settings key `thumb_max_dim_px`, 64–3840);
# higher = sharper stills but slower gen + bigger files. `withoutEnlargement`
# means sources smaller than this are never upscaled.
# CONTENT_BRIDGE_THUMB_MAX_DIM_PX=1080
# CONTENT_BRIDGE_THUMB_JPEG_QUALITY=80

# ─── OPTIONAL ──────────────────────────────────────────────────────────────

# Override the setup UI port if 8123 conflicts with something else on the
# host. Defaults to 8123 (prod compose); dev compose pins 8124; fresh creator
# installs (install scripts) use 8124. The port is bound to 127.0.0.1 only.
CONTENT_BRIDGE_SETUP_UI_PORT=

# ─── V0.8.b setup wizard / pairing ──────────────────────────────────────────

# Where the wizard's paired-state file (paired.json) lives inside the
# container. Defaults to <managed-root>/_state — i.e. UNDER the bridge-owned
# managed folder, the one RW area chowned to the run UID (same place _cache
# lives). NOT a Docker named volume (root-owned → a non-root container can't
# write it). Re-pair by deleting <managed>/_state/paired.json + restarting.
# CONTENT_BRIDGE_STATE_DIR=/data/managed/_state

# Optional pairing-code PREFILL for the setup wizard. Install scripts write the
# code the creator received here; the wizard uses it SERVER-SIDE to verify with
# the gateway before persisting (it is never sent to the browser — leaving the
# wizard's code field blank uses this value). Redundant once paired.json exists,
# so may be blanked after pairing completes (paired.json is the durable copy).
# CONTENT_BRIDGE_PAIRING_CODE=

# Dev/test ONLY: boot into the wizard even though CONTENT_BRIDGE_BEARER is set
# (the env bearer is ignored for the paired/unpaired decision; paired.json
# still wins when present). Lets the operator smoke the wizard on the dev
# stack without blanking the legacy bearer. Never set in production.
# CONTENT_BRIDGE_FORCE_WIZARD=false

# ─── V0.8.b "Both": headless auto-pair + token-gated LAN setup UI ───────────
# Two ways to pair a machine you can't open a browser ON (e.g. a NAS). Pick one.

# (1) AUTO-PAIR ON BOOT — no browser at all. When true AND a valid pairing code
# is present (CONTENT_BRIDGE_PAIRING_CODE above) AND the bridge is otherwise
# unpaired, the daemon verifies the code with the gateway and pairs itself at
# startup. The bridge's name comes from CONTENT_BRIDGE_DEVICE_LABEL (install
# scripts default it to the host's hostname); a fresh device-key UUID is saved
# to paired.json so a later rebuild at the same managed path re-attaches to the
# same device. A rejected code/name stops (no crash-loop); transient gateway
# errors retry a few times, then retry again on the next restart.
# CONTENT_BRIDGE_AUTO_PAIR=false

# (2) LAN SETUP PAGE — open the wizard from another computer on your network,
# protected by a token. Set these together with the port bind below:
#   CONTENT_BRIDGE_SETUP_UI_LAN=true
#   CONTENT_BRIDGE_SETUP_TOKEN=<32+ random hex; install scripts generate it>
#   CONTENT_BRIDGE_SETUP_UI_BIND=0.0.0.0
# In LAN mode every NON-loopback request to the setup UI must carry the token
# (X-Content-Bridge-Setup-Token header, or ?token=… on the first link). LAN mode
# with an EMPTY token FAILS CLOSED — every non-loopback request gets a 503.
# Loopback (the container healthcheck) is always allowed. With LAN mode OFF
# (default) the UI is localhost-only and the Host-header allowlist already
# rejects LAN browsers, so no token is needed.
# CONTENT_BRIDGE_SETUP_UI_LAN=false
# CONTENT_BRIDGE_SETUP_TOKEN=
# Optional: also allow this exact Host header in LAN mode (reach the NAS by name
# rather than IP, e.g. nas.local or nas.local:8124). Private-IP-literal hosts
# (10.x / 192.168.x / 172.16–31.x / 169.254.x) are allowed without this.
# CONTENT_BRIDGE_SETUP_UI_HOST=
# Host bind address for the setup-UI port. 127.0.0.1 = localhost only (default);
# 0.0.0.0 = LAN. Only set 0.0.0.0 together with LAN mode + a token above.
# CONTENT_BRIDGE_SETUP_UI_BIND=127.0.0.1

# Web-app base URL (e.g. https://app.example.com) — DISTINCT from the wss gateway
# URL (CONTENT_BRIDGE_SAAS_URL). Used only to build the "browse your content" link
# on the wizard success screen (points at <app-url>/content/bridge). This is an
# OVERRIDE of the bridge's built-in default (DEFAULT_APP_URL in src/config.ts,
# baked in at release); leave blank to use that default. Empty default + empty
# here = the link is hidden. This is the PROD value — it's what ships to customers.
# CONTENT_BRIDGE_APP_URL=

# Web-app base URL for DEV (used by docker-compose.dev.yml only; falls back to
# CONTENT_BRIDGE_APP_URL above when unset). A DEV-only var — keep it out of any
# .env shipped to customers, same as CONTENT_BRIDGE_BEARER_DEV.
# CONTENT_BRIDGE_APP_URL_DEV=

# ─── V0.6 narrow-bind + cache + managed folder ─────────────────────────────
#
# Phase F cutover (planning doc 65): your PRIMARY content root is
# CONTENT_BRIDGE_HOST_CONTENT_PATH above — the compose mirror-mounts it at
# /sources/host<host_path> and the bridge auto-registers it. ADDITIONAL roots
# (a second content folder) still use ./scripts/bridge-add-root.sh, which writes
# the mirrored bind into docker-compose.binds.yml. The vars below tune the cache
# + managed-folder boundaries; defaults are fine.

# Cache mount. PREFERRED setup: bind-mount a HOST dir you `chown` to the bridge
# UID (1031:100) onto this path — then the bridge fully owns the cache, so
# create+write+DELETE (eviction) all work with NO ACL grants and the cache stays
# OUT of the content tree. The bridge probes write access here and uses it when
# writable. Example bind (compose): `/volume1/docker/four-nations-bridge/cache:/data/cache`
# after `mkdir -p` + `chown -R 1031:100` that host dir.
# FALLBACK (no override / unwritable here): a hidden `_cache/` at the writable
# source root — works for create+write, but eviction then needs a delete grant
# on `_cache` (awkward on Synology). Prefer the owned bind above.
# CONTENT_BRIDGE_CACHE_ROOT=/data/cache

# Thumb output layout. cache_dir (DEFAULT post-cutover) = thumbs + 720p proxies
# under the cache mount (/data/cache/<deviceId>/<fileKey>/), never your content.
# in_place (write into each project's Pics/Bridge Thumbnails) is dormant — the
# Phase F cutover dropped the writable content mount, so in_place needs a writable
# mirrored mount re-added to use (planning doc 65).
# CONTENT_BRIDGE_THUMB_OUTPUT_MODE=cache_dir

# ─── V0.6.b cache + 720p preview-proxy knobs ───────────────────────────────
# All five are also live-overridable from the SaaS settings (same keys, minus
# the CONTENT_BRIDGE_ prefix + lowercased); the bridge re-clamps on receipt.
# 720p H.264 proxy quality (CRF; higher = smaller + lower quality). 18–35.
# CONTENT_BRIDGE_PROXY_QUALITY_CRF=28
# Max CPU threads for the proxy transcode. Default 2 (deliberately polite —
# previews are non-essential; leaves headroom for real workloads like Hyper
# Backup, and the renice keeps it low-priority on top). 0 = all cores (faster,
# hoggier); raise on beefy machines. Single-threaded was the multi-minute-per-
# file slowness.
# CONTENT_BRIDGE_PROXY_THREADS=2
# Skip proxy gen (stream source directly) for sources under this size — clips
# stream fine as-is; full videos / trailers get proxied. Bytes, 0–10GB.
# CONTENT_BRIDGE_PROXY_SKIP_BELOW_BYTES=100000000
# Proxy idle TTL in minutes (default 25). MUST exceed the gateway's pin window
# (15 min) or built proxies get evicted before they can be reused. 1–1440.
# CONTENT_BRIDGE_PROXY_CACHE_TTL_MINUTES=25
# Thumb TTL in days (browsed library-wide for weeks). 1–3650.
# CONTENT_BRIDGE_THUMB_CACHE_TTL_DAYS=90
# Hard cache-size ceiling (bytes; LRU eviction after TTL). 100MB–100GB.
# CONTENT_BRIDGE_CACHE_CAP_BYTES=2147483648
# How often the cache-eviction sweep runs (minutes, min 1). Default 5. Set to 1
# to watch eviction quickly during testing; raise it to reduce sweep overhead.
# CONTENT_BRIDGE_CACHE_SWEEP_MINUTES=5

# Managed folder — the single RW surface the bridge fully OWNS and exposes. The
# dev compose binds CONTENT_BRIDGE_MANAGED_HOST_PATH (a host dir you `chown` to
# the bridge UID — any NAS path, or a local path via Docker Desktop file sharing)
# onto CONTENT_BRIDGE_MANAGED_ROOT (`/data/managed`). It holds:
#   _cache/    — the bridge cache (thumbs in cache_dir mode + on-demand proxies;
#                eviction works because the bridge owns this volume — the cache
#                resolver PREFERS <managed>/_cache when it's writable)
#   template/  — the default project template (point DEFAULT_TEMPLATE_PATH here)
#   <projects> — where create-project scaffolds + the creator stores content
# Set CONTENT_BRIDGE_MANAGED_ENABLED=false to opt out (then cache falls back to a
# dedicated cache mount or the source-root `_cache`). Auto-registering the managed
# folder as a browsable source_root + onboarding UX land in V0.7; for now add it
# as a writable root via `bridge-add-root.sh <managed-host-path> --writable`.
# CONTENT_BRIDGE_MANAGED_ROOT=/data/managed
# CONTENT_BRIDGE_MANAGED_ENABLED=true
# CONTENT_BRIDGE_MANAGED_HOST_PATH=/volume1/docker/four-nations-bridge-managed-dev

# Default project-template folder (HOST path) that "Create Project Folder" copies
# when the operator doesn't override it per-create — e.g. your
# "00 - YYYY-MM-DD Project Template Folder". Must sit inside a bound root so the
# bridge can read it. Empty = no default (a templated create then errors; a
# plain-folder create still works). Can also be set live from the SaaS settings
# (`default_template_path`), which overlays this.
# CONTENT_BRIDGE_DEFAULT_TEMPLATE_PATH=
